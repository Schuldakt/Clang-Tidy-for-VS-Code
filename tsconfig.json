{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "types": [
            "node"
        ],
        "outDir": "out",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true
    },
    "include": [
        "src/packages/engine",
        "src/packages/lsp",
        "src/packages/ui",
        "src/packages/ui/webview",
        "src/extension.ts"
    ]
}